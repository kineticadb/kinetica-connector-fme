GUI IGNORE SourceDataset_KINETICA_1,KINETICA_IN_URL_KINETICA_1,KINETICA_IN_TABLENAME_KINETICA_1,KINETICA_IN_EXPRESSION_KINETICA_1,KINETICA_IN_USER_NAME_KINETICA_1,KINETICA_IN_PASSWORD_KINETICA_1,KINETICA_IN_EXPOSE_ATTRS_GROUP_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_MINX_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_MINY_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_MAXX_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_MAXY_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_KINETICA_1,KINETICA_IN_CLIP_TO_ENVELOPE_KINETICA_1,KINETICA_IN_NETWORK_AUTHENTICATION_KINETICA_1,DestDataset_KINETICA_2,KINETICA_OUT_WRITE_GEOMETRY_KINETICA_2,KINETICA_OUT_WRITE_POINTS_KINETICA_2,KINETICA_OUT_USER_NAME_KINETICA_2,KINETICA_OUT_PASSWORD_KINETICA_2
DEFAULT_MACRO SourceDataset_KINETICA abcd
GUI TEXT SourceDataset_KINETICA Source Kinetica Database(s):
DEFAULT_MACRO DestDataset_KINETICA test_fme_table2
GUI DIRNAME DestDataset_KINETICA Destination Kinetica Folder:
INCLUDE [ if {{$(SourceDataset_KINETICA)} == {}} { puts_real {Parameter 'SourceDataset_KINETICA' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(DestDataset_KINETICA)} == {}} { puts_real {Parameter 'DestDataset_KINETICA' must be given a value.}; exit 1; }; ]
#! START_HEADER
#! START_WB_HEADER
READER_TYPE KINETICA
READER_KEYWORD KINETICA_1
READER_GEN_DIRECTIVES SEARCH_ENVELOPE_MINY,0,USE_SEARCH_ENVELOPE,NO,CLIP_TO_ENVELOPE,NO,KINETICA_EXPOSE_FORMAT_ATTRS,,SEARCH_ENVELOPE_MAXY,0,TABLENAME,test_fme_table1,_MERGE_SCHEMAS,YES,URL,http:<solidus><solidus>172.30.195.3:9191,SEARCH_ENVELOPE_MINX,0,SEARCH_ENVELOPE_COORDINATE_SYSTEM,,USER_NAME,,EXPOSE_ATTRS_GROUP,FME_DISCLOSURE_CLOSED,EXPRESSION,,SEARCH_ENVELOPE_MAXX,0

WRITER_TYPE MULTI_WRITER
MULTI_WRITER_DATASET_ORDER BY_ID
MULTI_WRITER_FIRST_WRITER_ID 0
MULTI_WRITER_TYPE{0} KINETICA
MULTI_WRITER_KEYWORD{0} KINETICA_2
#! END_WB_HEADER

#! START_WB_HEADER
MACRO WB_KEYWORD "KINETICA_1"
#! END_WB_HEADER
#! START_SOURCE_HEADER KINETICA KINETICA_1
# The dataset this mapping file was generated from was:
#! END_SOURCE_HEADER
