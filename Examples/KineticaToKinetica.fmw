#! START_WB_HEADER
DEFAULT_MACRO DestDataset
INCLUDE [ if {"$(DestDataset)" != ""} {                          \
 puts {DEFAULT_MACRO DestDataset_KINETICA_2 $(DestDataset)}         \
 } ]
#! END_WB_HEADER
#! START_DEST_HEADER KINETICA KINETICA_2
DEFAULT_MACRO DestDataset_KINETICA_2 $(DestDataset_KINETICA)
GUI DIRNAME DestDataset_KINETICA_2 Destination Kinetica Folder:
DEFAULT_MACRO KINETICA_OUT_URL_KINETICA_2 http://172.30.195.3:9191
KINETICA_2_URL "$(KINETICA_OUT_URL_KINETICA_2)"
DEFAULT_MACRO KINETICA_OUT_COLLECTION_NAME_KINETICA_2 
KINETICA_2_COLLECTION_NAME "$(KINETICA_OUT_COLLECTION_NAME_KINETICA_2)"
DEFAULT_MACRO KINETICA_OUT_WRITE_GEOMETRY_KINETICA_2 NO
KINETICA_2_WRITE_GEOMETRY "$(KINETICA_OUT_WRITE_GEOMETRY_KINETICA_2)"
GUI ACTIVEDISCLOSUREGROUP KINETICA_OUT_WRITE_GEOMETRY_KINETICA_2 KINETICA_OUT_GEOMETRY_KEY Write Geometry
DEFAULT_MACRO KINETICA_OUT_GEOMETRY_KEY_KINETICA_2 <Unused>
KINETICA_2_GEOMETRY_KEY "$(KINETICA_OUT_GEOMETRY_KEY_KINETICA_2)"
DEFAULT_MACRO KINETICA_OUT_WRITE_POINTS_KINETICA_2 NO
KINETICA_2_WRITE_POINTS "$(KINETICA_OUT_WRITE_POINTS_KINETICA_2)"
GUI ACTIVEDISCLOSUREGROUP KINETICA_OUT_WRITE_POINTS_KINETICA_2 KINETICA_OUT_POINT_X%KINETICA_OUT_POINT_Y Write Points
DEFAULT_MACRO KINETICA_OUT_POINT_X_KINETICA_2 <Unused>
KINETICA_2_POINT_X "$(KINETICA_OUT_POINT_X_KINETICA_2)"
DEFAULT_MACRO KINETICA_OUT_POINT_Y_KINETICA_2 <Unused>
KINETICA_2_POINT_Y "$(KINETICA_OUT_POINT_Y_KINETICA_2)"
DEFAULT_MACRO KINETICA_OUT_USER_NAME_KINETICA_2 
KINETICA_2_USER_NAME "$(KINETICA_OUT_USER_NAME_KINETICA_2)"
GUI OPTIONAL TEXT KINETICA_OUT_USER_NAME_KINETICA_2 Username:
DEFAULT_MACRO KINETICA_OUT_PASSWORD_KINETICA_2 
KINETICA_2_PASSWORD "$(KINETICA_OUT_PASSWORD_KINETICA_2)"
GUI OPTIONAL PASSWORD KINETICA_OUT_PASSWORD_KINETICA_2 Password:
KINETICA_2_DATASET "$(DestDataset_KINETICA_2)"
