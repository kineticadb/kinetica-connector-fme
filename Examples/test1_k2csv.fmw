GUI IGNORE SourceDataset_KINETICA_1,KINETICA_IN_URL_KINETICA_1,KINETICA_IN_TABLENAME_KINETICA_1,KINETICA_IN_EXPRESSION_KINETICA_1,KINETICA_IN_USER_NAME_KINETICA_1,KINETICA_IN_PASSWORD_KINETICA_1,KINETICA_IN_EXPOSE_ATTRS_GROUP_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_MINX_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_MINY_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_MAXX_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_MAXY_KINETICA_1,KINETICA_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_KINETICA_1,KINETICA_IN_CLIP_TO_ENVELOPE_KINETICA_1,KINETICA_IN_NETWORK_AUTHENTICATION_KINETICA_1,DestDataset_KINETICA_3,KINETICA_OUT_WRITE_GEOMETRY_KINETICA_3,KINETICA_OUT_WRITE_POINTS_KINETICA_3,KINETICA_OUT_USER_NAME_KINETICA_3,KINETICA_OUT_PASSWORD_KINETICA_3
