READER_GEN_DIRECTIVES SEARCH_ENVELOPE_MINY,0,EXPOSE_ATTRS_GROUP,,_MERGE_SCHEMAS,YES,TABLENAME,test_table_all_but_charN,EXPRESSION,,SEARCH_ENVELOPE_MINX,0,SEARCH_ENVELOPE_MAXY,0,CLIP_TO_ENVELOPE,NO,URL,http:<solidus><solidus>172.30.60.178:9191,USE_SEARCH_ENVELOPE,NO,SEARCH_ENVELOPE_COORDINATE_SYSTEM,,KINETICA_EXPOSE_FORMAT_ATTRS,,USER_NAME,,SEARCH_ENVELOPE_MAXX,0

WRITER_TYPE MULTI_WRITER
MULTI_WRITER_DATASET_ORDER BY_ID
MULTI_WRITER_FIRST_WRITER_ID 0
MULTI_WRITER_TYPE{0} KINETICA
MULTI_WRITER_KEYWORD{0} KINETICA_3
