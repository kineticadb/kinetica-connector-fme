LOG_FILENAME "$(FME_HOME)pluginbuilder\gpudb-connector-fme\Examples\test.log"
LOG_APPEND NO
LOG_MAX_FEATURES 200
LOG_MAX_RECORDED_FEATURES 200
FME_REPROJECTION_ENGINE FME
FME_IMPLICIT_CSMAP_REPROJECTION_MODE Auto
FME_GEOMETRY_HANDLING Enhanced
FME_STROKE_MAX_DEVIATION 0
LOG_FILTER_MASK -1
DEFAULT_MACRO DATASET_KEYWORD_KINETICA_1 KINETICA_1
DEFAULT_MACRO DATASET_KEYWORD_KINETICA_2 KINETICA_2
DEFAULT_MACRO DATASET_KEYWORD_CSV2_1 CSV2_1
DEFAULT_MACRO DATASET_KEYWORD_CSV2_2 CSV2_2
DEFAULT_MACRO DATASET_KEYWORD_KINETICA_3 KINETICA_3
# -------------------------------------------------------------------------

KINETICA_1_READER_META_ATTRIBUTES fme_feature_type

# -------------------------------------------------------------------------

KINETICA_2_READER_META_ATTRIBUTES fme_feature_type

# -------------------------------------------------------------------------

MULTI_READER_CONTINUE_ON_READER_FAILURE No

# -------------------------------------------------------------------------

MACRO WORKSPACE_NAME test
MACRO FME_VIEWER_APP fmedatainspector
# -------------------------------------------------------------------------
KINETICA_1_DEF KineticaFeatureType   wkt                          string
# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE KINETICA KINETICA_1::KineticaFeatureType multi_reader_keyword,$(DATASET_KEYWORD_KINETICA_1) TO FME_GENERIC ::KineticaFeatureType ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
KINETICA_1_MERGE_DEF KINETICA_1::KineticaFeatureType EXACT KineticaFeatureType
KINETICA_2_MERGE_DEF KINETICA_2::KineticaFeatureType EXACT KineticaFeatureType
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "KineticaFeatureType (KINETICA_1) Splitter"    INPUT FEATURE_TYPE KineticaFeatureType      multi_reader_keyword $(DATASET_KEYWORD_KINETICA_1)    OUTPUT FEATURE_TYPE KineticaFeatureType_KINETICA_1
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "KineticaFeatureType (KINETICA_2) Splitter"    INPUT FEATURE_TYPE KineticaFeatureType      multi_reader_keyword $(DATASET_KEYWORD_KINETICA_2)    OUTPUT FEATURE_TYPE KineticaFeatureType_KINETICA_2
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory FACTORY_NAME "Destination Feature Type Routing Correlator"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE FME_GENERIC KineticaFeatureType_KINETICA_1 TO KINETICA __GO_TO_FINAL_OUTPUT_ROUTER__ multi_writer_id,2,<at>SupplyAttributes<openparen>ENCODED<comma>__wb_out_feat_type__<comma>geom_kin<closeparen> GEOMETRY    ROUTE FME_GENERIC KineticaFeatureType_KINETICA_2 TO NULL __GO_TO_FINAL_OUTPUT_ROUTER__ multi_writer_id,1,__wb_out_feat_type__,__nuke_me__ GEOMETRY   FEATURE_TYPE_ATTRIBUTE __wb_out_feat_type__   OUTPUT ROUTED FEATURE_TYPE *    OUTPUT NOT_ROUTED FEATURE_TYPE __nuke_me__ @Tcl2("FME_StatMessage 818059 [FME_GetAttribute fme_template_feature_type] 818060 818061 fme_warn")
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory   FACTORY_NAME "Final Output Nuker"   INPUT FEATURE_TYPE __nuke_me__

# -------------------------------------------------------------------------
KINETICA_3_DEF geom_kin   wkt                          WKT
# -------------------------------------------------------------------------
KINETICA_3_DEF test_wkty_only_kinetica   wkt                          WKT
